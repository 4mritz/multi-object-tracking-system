models/detection/*.pt

# =========================
# Data (Heavy Files)
# =========================
data/raw/*
data/processed/*

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# =========================
# Results / Outputs
# =========================
results/videos/*
results/logs/*
results/plots/*

# Keep structure
!results/videos/.gitkeep
!results/logs/.gitkeep
!results/plots/.gitkeep

# =========================
# Notebooks Outputs
# =========================
notebooks/*.ipynb

# Optional: keep notebook but strip outputs manually if needed

# =========================
# Logs
# =========================
*.log

# =========================
# Temporary Files
# =========================
*.tmp
*.swp


